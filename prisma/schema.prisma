generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum STATUS{
  SENT
  CONFIRMED
  REJECTED
}

model Users{
  userId String @id @default(uuid())
  username String @unique
  name String
  email String @unique
  password String
  
  userFriends Friends[] @relation("UserFriends")
  friendRelations Friends[] @relation("FriendRelation")
}
model Friends{
  userId String
  friendId String
  status STATUS @default(SENT)
  user Users @relation("UserFriends", fields: [userId], references: [userId])
  friend Users @relation("FriendRelation", fields: [friendId], references: [userId])

  @@id([userId,friendId])
}